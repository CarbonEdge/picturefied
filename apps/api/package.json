{
  "name": "@picturefied/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file=../../.env dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@picturefied/crypto": "workspace:*",
    "@picturefied/storage": "workspace:*",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0",
    "ioredis": "^5.4.0",
    "jose": "^5.9.0",
    "@simplewebauthn/server": "^10.0.0",
    "argon2": "^0.41.0",
    "zod": "^3.23.0",
    "@hono/zod-validator": "^0.4.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.0",
    "@types/node": "^22.0.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  }
}
