# ─── Required ────────────────────────────────────────────────────────────────

# Postgres connection string
DATABASE_URL=postgresql://picturefied:changeme@localhost:5432/picturefied

# Redis/Valkey connection string
REDIS_URL=redis://localhost:6379

# 64-byte hex secret for signing JWTs — generate with: openssl rand -hex 64
JWT_SECRET=replace_me_with_openssl_rand_hex_64

# Access token lifetime (default 15 minutes)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime (default 30 days)
JWT_REFRESH_EXPIRES_IN=30d

# Your public domain (used for WebAuthn rpId and share link URLs)
DOMAIN=localhost

# Public base URL (used for share link construction)
PUBLIC_URL=http://localhost:3000

# ─── Storage Backend (pick one) ───────────────────────────────────────────────

# Local filesystem (good for single-server / dev)
STORAGE_BACKEND=local
STORAGE_ROOT=./data/files

# S3-compatible (uncomment and fill to use instead)
# STORAGE_BACKEND=s3
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=picturefied-files
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false

# ─── Optional ─────────────────────────────────────────────────────────────────

# Set to true to require invite codes for new registrations
INVITE_ONLY=false

# Max upload size in bytes (default 2GB)
MAX_UPLOAD_BYTES=2147483648

# SMTP for share notification emails (optional — shares work without this)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

# API port
PORT=8787

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
