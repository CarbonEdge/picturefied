# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Required: your Google Cloud OAuth 2.0 Client ID.
# Create one at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised JavaScript origins:
#   http://localhost:5173            (local dev)
#   https://yourusername.github.io   (production)
VITE_GOOGLE_CLIENT_ID=

# ─── SuperTokens ──────────────────────────────────────────────────────────────
# The Cloudflare Worker URL that hosts the SuperTokens backend.
# Local dev: http://localhost:8787
# Production: https://picturefied-api.YOUR_SUBDOMAIN.workers.dev
VITE_API_URL=http://localhost:8787

# Your GitHub Pages URL (used by SuperTokens to set cookie domain).
# Local dev: http://localhost:5173
# Production: https://yourusername.github.io
VITE_PUBLIC_URL=http://localhost:5173

# ─── GitHub Pages base path ───────────────────────────────────────────────────
# '/' for user/org sites (username.github.io)
# '/picturefied/' for project sites (username.github.io/picturefied)
VITE_BASE_PATH=/
